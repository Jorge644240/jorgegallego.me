<!DOCTYPE html>

<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta http-equiv="X-UA-Compatible" content="IE=edge">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <meta name="author" content="Jorge Gallego">
        <meta name="title" content="My Portfolio - Jorge Gallego">
        <meta name="keywords" content="Jorge, Gallego, Jorge Gallego, Full Stack developer, Full Stack Web Developer, Web Developer, Front End developer, Front End Web Developer, Back End developer, Back End Web developer, Vue developer, Node developer, Node.js, Vue.js, VueJS, Flask developer, Django developer, MySQL, PostgreSQL, MongoDB, jQuery, MP Consultores SAS, NGINX, Ubuntu, VPS, Virtual Private Server, Databse Design, Database Administration, DBD, DBA, DBD/DBA, Web Designer, Universidad del Rosario, Web developer near me, Web developer in Bogota, Web developer in Colombia">
        <meta name="description" content="My name is Jorge Gallego, and I'm a Full Stack Web developer. I am skilled and experienced in using nothing but the best tools in the market for web development, which allows me to help businesses establish and grow a virtual presence while also driving in new visitors to their website and new clients to the company.">
        <title>My Portfolio - Jorge Gallego</title>
        <link rel="canonical" href="https://jorgegallego.me/portfolio">
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&family=Raleway:wght@400;500;600;700&family=Zilla+Slab&family=Poppins&family=Questrial&display=swap" rel="stylesheet">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.5.0/font/bootstrap-icons.css">
        <link rel="stylesheet" href="/css/index.css">
        <script src="https://kit.fontawesome.com/313f6b6c56.js" crossorigin="anonymous"></script>
        <script async src="https://www.googletagmanager.com/gtag/js?id=UA-201835114-1"></script>
        <script>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
        
          gtag('config', 'UA-201835114-1');
        </script>
    </head>
    <body>
        <button class="color-theme" onclick="changeColorTheme()">
            <i class="bi-sun-fill" title="Switch to Dark Mode"></i>
        </button>
        <header id="title">
            <nav>
                <article>
                    <aside class="expand-menu">
                        <i class="bi-list"></i>
                    </aside>
                    <aside class="links">
                        <a href="/" class="link">HOME</a>
                        <a href="#portfolio" class="link">PORTFOLIO</a>
                    </aside>
                </article>
            </nav>
            <article class="center">
                <h1>My Portfolio</h1>
            </article>
            <a href="#portfolio">
                <i class="bi-arrow-down-short"></i>
            </a>
        </header>
        <section id="portfolio">
            <article class="card-group">
                <% for (let project of projects) { %>
                    <div class="card">
                        <div class="card-header">
                            <h3><%= project.name %></h3>
                            <a href="<%= project.target %>" target="_blank" rel="noopener noreferrer">View Project</a>
                        </div>
                        <div class="card-body">
                            <img src="<%= project.img.source %>" alt="<%= project.img.alt %>">
                            <p><%= project.description %></p>
                        </div>
                    </div>
                <% } %>
            </article>
        </section>
        <footer>
            <h2>Follow Me</h2>
            <p class="icons">
                <a href="https://www.linkedin.com/in/jorge-gallego-6b641b1b1/" target="_blank" title="LinkedIn" rel="noreferrer">
                    <i class="bi-linkedin"></i>
                </a>
                <a href="http://twitter.com/jorge__gallego" target="_blank" title="Twitter" rel="noreferrer">
                    <i class="bi-twitter"></i>
                </a>
                <a href="https://github.com/Jorge644240" target="_blank" title="GitHub" rel="noreferrer">
                    <i class="bi-github"></i>
                </a>
            </p>
        </footer>
        <script src="/js/colorTheme.js"></script>
        <script src="/js/index.js"></script>
    </body>
</html>